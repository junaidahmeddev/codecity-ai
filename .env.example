# ─── Runtime ────────────────────────────────────────────────
# Node environment
NODE_ENV=development

# ─── Backend ────────────────────────────────────────────────
# Fastify server
API_HOST=0.0.0.0
API_PORT=3001

# Redis (used by BullMQ job queue + parsed-repo cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Ingestion Pipeline Security Guardrails ─────────────────
# All limits are enforced in @codecity/shared config module.
# Override here per-environment; defaults are safe production values.
CLONE_TIMEOUT_MS=60000
MAX_REPO_SIZE_MB=500
MAX_WALK_DEPTH=30
MAX_FILE_SIZE_KB=1024
PARSE_TIMEOUT_PER_FILE_MS=5000

# ─── Frontend ───────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ─── Observability ──────────────────────────────────────────
# OpenTelemetry collector endpoint (Phase 6)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info
