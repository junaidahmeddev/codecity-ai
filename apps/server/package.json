{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run copy-grammars && tsx watch src/server.ts",
    "copy-grammars": "node scripts/copy-grammars.js",
    "build": "npm run copy-grammars && tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codecity/shared-types": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@trpc/server": "^11.18.0",
    "bullmq": "^5.79.2",
    "fastify": "^5.9.0",
    "ioredis": "^5.11.1",
    "pino": "^9.7.0",
    "simple-git": "^3.36.0",
    "web-tree-sitter": "^0.26.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "pino-pretty": "^13.1.3",
    "tree-sitter-wasms": "^0.1.13",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
