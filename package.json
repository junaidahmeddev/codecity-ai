{
  "name": "codecity-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Transform GitHub repositories into interactive 3D Cyberpunk Metropolises",
  "scripts": {
    "dev": "pnpm --filter=web dev & pnpm --filter=server dev",
    "dev:web": "pnpm --filter=web dev",
    "dev:server": "pnpm --filter=server dev",
    "build:shared": "pnpm --filter=shared-types build",
    "build": "pnpm --filter=shared-types build && pnpm --filter=server build && pnpm --filter=web build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
